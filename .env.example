# Database Configuration (Configuration Map Database)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_config_database

# Main Data Database (where source and destination tables reside)
DB_DATA_NAME=your_data_database

# Logging Configuration
LOG_LEVEL=INFO

# Advanced Concurrency & Scheduling Defaults
MAX_WORKERS=4
DEFAULT_FREQUENCY=d-1
